{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Snipe-IT Azure Integration Configuration",
  "type": "object",
  "required": ["SnipeIt", "Azure", "Sync", "FieldMappings", "Logging", "Retry"],
  "additionalProperties": false,
  "properties": {
    "SnipeIt": {
      "type": "object",
      "required": ["BaseUrl", "ApiTokenEnvironmentVariable", "PageSize"],
      "additionalProperties": false,
      "properties": {
        "BaseUrl": { "type": "string", "format": "uri", "pattern": "^https://" },
        "ApiTokenEnvironmentVariable": { "type": "string", "minLength": 1 },
        "PageSize": { "type": "integer", "minimum": 1, "maximum": 500 }
      }
    },
    "Azure": {
      "type": "object",
      "required": ["TenantIdEnvironmentVariable", "ClientIdEnvironmentVariable", "CertificateThumbprintEnvironmentVariable", "Source"],
      "additionalProperties": false,
      "properties": {
        "TenantIdEnvironmentVariable": { "type": "string", "minLength": 1 },
        "ClientIdEnvironmentVariable": { "type": "string", "minLength": 1 },
        "CertificateThumbprintEnvironmentVariable": { "type": "string", "minLength": 1 },
        "Source": { "type": "string", "enum": ["IntuneManagedDevices"] }
      }
    },
    "Sync": {
      "type": "object",
      "required": ["Mode", "MatchPriority", "BadSerialNumbers", "UpdateFields", "CreateFields"],
      "additionalProperties": false,
      "properties": {
        "Mode": { "type": "string", "enum": ["Plan", "Apply"] },
        "MatchPriority": {
          "type": "array",
          "items": { "type": "string", "enum": ["SerialNumber", "AzureDeviceId", "IntuneDeviceId", "DeviceName"] },
          "minItems": 1,
          "uniqueItems": true
        },
        "BadSerialNumbers": { "type": "array", "items": { "type": "string" } },
        "UpdateFields": {
          "type": "array",
          "items": { "type": "string", "enum": ["DeviceName", "Manufacturer", "Model", "AzureDeviceId", "IntuneDeviceId", "AssignedUser"] },
          "uniqueItems": true
        },
        "CreateFields": {
          "type": "array",
          "items": { "type": "string", "enum": ["SerialNumber", "DeviceName", "Manufacturer", "Model", "AzureDeviceId", "IntuneDeviceId", "AssignedUser"] },
          "minItems": 1,
          "uniqueItems": true
        }
      }
    },
    "FieldMappings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "SerialNumber": { "type": "string" },
        "DeviceName": { "type": "string" },
        "Manufacturer": { "type": "string" },
        "Model": { "type": "string" },
        "AzureDeviceId": { "type": "string" },
        "IntuneDeviceId": { "type": "string" },
        "AssignedUser": { "type": "string" }
      }
    },
    "Logging": {
      "type": "object",
      "required": ["LogPath", "ReportPath"],
      "additionalProperties": false,
      "properties": {
        "LogPath": { "type": "string", "minLength": 1 },
        "ReportPath": { "type": "string", "minLength": 1 }
      }
    },
    "Retry": {
      "type": "object",
      "required": ["MaxAttempts", "InitialDelaySeconds", "MaxDelaySeconds"],
      "additionalProperties": false,
      "properties": {
        "MaxAttempts": { "type": "integer", "minimum": 1, "maximum": 10 },
        "InitialDelaySeconds": { "type": "integer", "minimum": 1, "maximum": 60 },
        "MaxDelaySeconds": { "type": "integer", "minimum": 1, "maximum": 300 }
      }
    }
  }
}
