{
  "SnipeIt": {
    "BaseUrl": "https://snipeit.example.com",
    "ApiTokenEnvironmentVariable": "SNIPEIT_API_TOKEN",
    "PageSize": 100
  },
  "Azure": {
    "TenantIdEnvironmentVariable": "AZURE_TENANT_ID",
    "ClientIdEnvironmentVariable": "AZURE_CLIENT_ID",
    "CertificateThumbprintEnvironmentVariable": "AZURE_CERT_THUMBPRINT",
    "Source": "IntuneManagedDevices"
  },
  "Sync": {
    "Mode": "Plan",
    "UniqueMatchPriority": [
      "SerialNumber",
      "AzureDeviceId",
      "IntuneDeviceId"
    ],
    "FallbackMatchPriority": [
      "DeviceName"
    ],
    "BadSerialNumbers": [
      "To Be Filled By O.E.M.",
      "System Serial Number",
      "Default string",
      "00000000",
      "None",
      "Unknown"
    ],
    "UpdateFields": [
      "DeviceName",
      "Manufacturer",
      "Model",
      "AzureDeviceId",
      "IntuneDeviceId",
      "AssignedUser"
    ]
  },
  "FieldMappings": {
    "SerialNumber": "serial",
    "DeviceName": "name",
    "Manufacturer": "manufacturer",
    "Model": "model",
    "AzureDeviceId": "_snipeit_azure_device_id_1",
    "IntuneDeviceId": "_snipeit_intune_device_id_2",
    "AssignedUser": "assigned_user"
  },
  "Logging": {
    "LogPath": "C:/ProgramData/SnipeITAzureSync/logs/snipeit-azure-sync.jsonl",
    "ReportPath": "C:/ProgramData/SnipeITAzureSync/reports/snipeit-azure-sync-report.json"
  },
  "Retry": {
    "MaxAttempts": 4,
    "InitialDelaySeconds": 2,
    "MaxDelaySeconds": 30
  }
}
